__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Local configuration and secrets
.env
.env.*
.streamlit/secrets.toml

# Streamlit runtime logs
streamlit*.log

# Browser debug/runtime folders
.chrome-debug-test/
.chrome-relationship/
.chrome*/
.edge-debug/
.edge-shot/
